{
  "name": "webslugba/notification-service",
  "description": "Notification microservice test assignment.",
  "type": "project",
  "license": "MIT",
  "require": {
    "php": "^8.4",
    "laravel/framework": "^12.0",
    "php-amqplib/php-amqplib": "^3.7"
  },
  "require-dev": {
    "fakerphp/faker": "^1.24",
    "mockery/mockery": "^1.6",
    "nunomaduro/collision": "^8.6",
    "phpunit/phpunit": "^11.5"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "post-autoload-dump": [
      "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump"
    ],
    "test": "php artisan test"
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
